# ─────────────────────────────────────────────────────────────────────────────
# Local development secrets for `wrangler dev`.
# Copy to `.dev.vars` and fill in real values. NEVER commit `.dev.vars`.
#
# In PRODUCTION these are set with `wrangler secret put <NAME>` (NOT in wrangler.toml).
# Public config (SUPABASE_PROJECT_URL / SUPABASE_ANON_KEY / SUPABASE_JWKS_URL /
# CREEM_PRODUCT_ID) lives in wrangler.toml [vars] — see that file.
# ─────────────────────────────────────────────────────────────────────────────

# DeepSeek (LLM / chat) — https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-deepseek-key

# Alibaba Bailian / DashScope (Vision = qwen-vl-max, ASR = qwen3-asr-flash +
# paraformer-realtime-v2) — https://bailian.console.aliyun.com
BAILIAN_API_KEY=sk-your-dashscope-key

# Supabase service role key (server-side admin key) — Project Settings > API
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Creem payments (test mode keys are prefixed creem_test_) — https://creem.io
CREEM_API_KEY=creem_test_your-key
CREEM_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# The following mirror wrangler.toml [vars]; wrangler dev reads them from there,
# but you can override locally if needed:
# SUPABASE_PROJECT_URL=https://YOUR-PROJECT.supabase.co
# SUPABASE_ANON_KEY=sb_publishable_xxx
